# ============================================================
# Variables d'environnement EDS22 — Backend
# Copier ce fichier en .env et renseigner les valeurs
# ============================================================

# Serveur
PORT=5001
NODE_ENV=production

# Base de données MongoDB
MONGODB_URI=mongodb://localhost:27017/eds22

# JWT — Secret pour les tokens d'authentification interne
# Générer une valeur aléatoire forte en production
JWT_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET

# OpenRouter — Clé API pour le module IA
OPENROUTER_API_KEY=sk-or-v1-...

# API Boutique — Clé secrète pour l'API publique /api/v1/products
# Utilisée par le site web pour afficher les produits EDS22
# Générer avec : openssl rand -hex 32
API_SECRET_KEY=CHANGE_ME_STRONG_RANDOM_KEY
